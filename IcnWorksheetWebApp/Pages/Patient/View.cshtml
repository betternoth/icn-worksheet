@page "{id:int}"
@model ViewModel
@{
    ViewData["Title"] = "Patient Details";
}

<div class="container mt-5">
    <div class="row mb-3">
        <div class="col-12">
            <h1>@ViewData["Title"]</h1>
        </div>
    </div>

    @if (Model.Patient == null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle"></i> Patient not found.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <!-- Patient Information Card -->
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">Patient Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-12">
                                <h6 class="text-muted">Full Name</h6>
                                <p class="fs-5"><strong>@Model.Patient.FullName</strong></p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">First Name</h6>
                                <p>@Model.Patient.FirstName</p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Last Name</h6>
                                <p>@Model.Patient.LastName</p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-12">
                                <h6 class="text-muted">Hospital Number (HN)</h6>
                                <p><span class="badge bg-info">@Model.Patient.HospitalNumber</span></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="row mt-4 mb-4">
                    <div class="col-12">
                        <div class="d-flex gap-2">
                            <a href="/Patient/Edit/@Model.Patient.Id" class="btn btn-primary">
                                <i class="bi bi-pencil"></i> Edit Patient
                            </a>
                            <a href="/Patient/Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
