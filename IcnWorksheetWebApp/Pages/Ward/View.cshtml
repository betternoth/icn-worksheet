@page "{id:int}"
@model ViewModel
@{
    ViewData["Title"] = "Ward Details";
}

<div class="container mt-5">
    <div class="row mb-3">
        <div class="col-12">
            <h1>@ViewData["Title"]</h1>
        </div>
    </div>

    @if (Model.Ward == null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle"></i> Ward not found.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <!-- Ward Information Card -->
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">Ward Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-12">
                                <h6 class="text-muted">Name</h6>
                                <p class="fs-5"><strong>@Model.Ward.Name</strong></p>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h6 class="text-muted">Group</h6>
                                <p>
                                    <span class="badge bg-info">@Model.Ward.Group</span>
                                </p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-muted">Type</h6>
                                <p>
                                    @if (Model.Ward.Type == "ICU")
                                    {
                                        <span class="badge bg-danger">@Model.Ward.Type</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@Model.Ward.Type</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="row mt-4 mb-4">
                    <div class="col-12">
                        <div class="d-flex gap-2">
                            <a href="/Ward/Edit/@Model.Ward.Id" class="btn btn-primary">
                                <i class="bi bi-pencil"></i> Edit Ward
                            </a>
                            <a href="/Ward/Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
