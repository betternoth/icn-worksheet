@page
@model IndexModel
@{
    ViewData["Title"] = "Ward Management";
}

<div class="container-fluid mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1>@ViewData["Title"]</h1>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-12">
            <a href="/Ward/Add" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Ward
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            @if (Model.Wards == null || !Model.Wards.Any())
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle"></i> No wards found. 
                    <a href="/Ward/Add">Click here to add a new ward</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>Group</th>
                                <th>Type</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ward in Model.Wards)
                            {
                                <tr>
                                    <td><strong>@ward.Name</strong></td>
                                    <td>
                                        <span class="badge bg-info">@ward.Group</span>
                                    </td>
                                    <td>
                                        @if (ward.Type == "ICU")
                                        {
                                            <span class="badge bg-danger">@ward.Type</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">@ward.Type</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="/Ward/Edit/@ward.Id" class="btn btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/Ward/View/@ward.Id" class="btn btn-outline-info" title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="/Ward/Delete/@ward.Id" class="btn btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
