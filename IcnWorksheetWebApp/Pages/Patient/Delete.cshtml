@page "{id:int}"
@model DeleteModel
@{
    ViewData["Title"] = "Delete Patient";
}

<div class="container mt-5">
    <div class="row mb-3">
        <div class="col-12">
            <h1>@ViewData["Title"]</h1>
        </div>
    </div>

    @if (Model.Patient == null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle"></i> Patient not found.
        </div>
        <a href="/Patient/Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    }
    else
    {
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="card-title mb-0">⚠️ Confirm Deletion</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-danger mb-4">
                            <strong>Are you sure you want to delete this patient?</strong>
                        </p>
                        <p class="text-muted">This action cannot be undone.</p>

                        <!-- Patient Details for Confirmation -->
                        <div class="alert alert-light border border-danger mt-4">
                            <div class="row mb-2">
                                <div class="col-4">
                                    <strong>Hospital Number (HN):</strong>
                                </div>
                                <div class="col-8">
                                    <span class="badge bg-info">@Model.Patient.HospitalNumber</span>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-4">
                                    <strong>Full Name:</strong>
                                </div>
                                <div class="col-8">
                                    @Model.Patient.GetFullName()
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-4">
                                    <strong>First Name:</strong>
                                </div>
                                <div class="col-8">
                                    @Model.Patient.FirstName
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light">
                        <form method="post">
                            <input type="hidden" name="id" value="@Model.Patient.Id" />
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-trash"></i> Delete Patient
                                </button>
                                <a href="/Patient/Index" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
